{
  "name": "react-native-google-play-games",
  "version": "0.1.0",
  "description": "Android-only React Native TurboModule for Google Play Games Services.",
  "keywords": [
    "react-native",
    "android",
    "google-play-games",
    "turbo-module"
  ],
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "react-native": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "android",
    "src",
    "react-native.config.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.80.0"
  },
  "codegenConfig": {
    "name": "RNGooglePlayGamesSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativegoogleplaygames"
    }
  }
}
